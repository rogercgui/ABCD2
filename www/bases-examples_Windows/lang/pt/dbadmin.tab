set_TIP_DATE_FORMAT=Defina o formato da data. Veja a documentaçăo do PHP.<br><b>Y</b> = ano, quatro dígitos, <b>m</b> = męs do ano, 2 dígitos com zero ŕ esquerda, <b>d</b> = dia do męs, 2 dígitos com zero ŕ esquerda
set_TIP_NEW_WINDOW=Marque se vocę deseja que o ABCD seja aberto em uma nova janela após o login.
set_TIP_LOGO_DEFAULT=Marque para exibir o logotipo padrăo do ABCD.
