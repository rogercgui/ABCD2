set_TIP_RESERVATION=Ativar o módulo de reserva.
set_TIP_LOAN_POLICY=POR_USUÁRIO significa que no sistema de empréstimo o operador terá as políticas ŕs quais o usuário tem acesso apresentadas para que ele possa selecionar a que deseja aplicar ao título no processo de empréstimo
set_TIP_EMAIL=
set_TIP_AC_SUSP=Para que os termos de suspensăo sejam cumulativos, ou seja, se um usuário já estiver suspenso, a nova suspensăo terá efeito a partir do final da suspensăo anterior.
set_TIP_ASK_LPN=Esta opçăo solicita os dias de empréstimo no momento de inserir o código do usuário e o número de inventário para empréstimo.
set_TIP_ILLOAN=Ativar empréstimo interbibliotecário.
set_TIP_UNICODE=Define a codificaçăo para a base de dados e a interface.<br> Unicode=Sim &rarr; UTF-8, Unicode=Năo &rarr; ISO-8859-1
set_TIP_CISIS_VERSION=Define a arquitetura da base de dados. A combinaçăo do parâmetro UNICODE com o parâmetro CISIS_VERSION determina a subpasta dentro da pasta cgi-bin com os executáveis aplicáveis (wxis,mx,...)
set_TIP_REG_LOG=Ativa o registro de log.<br>Requer a existęncia do diretório "bases/log"
set_TIP_DIRTREE=Ativa ou desativa a permissăo para navegar na pasta da base de dados ativa ou nas pastas www, par e wrk do diretório de bases de dados.
set_TIP_DIRTREE_EXT=Define as extensőes de arquivo que podem ser exibidas ao navegar na pasta "bases", na pasta de uma base de dados específica, par, www ou wrk.
set_TIP_CHANGE_PASSWORD=Permite que os operadores alterem sua senha.
set_TIP_SECURE_PASSWORD_LENGTH=Comprimento mínimo que a chave de acesso deve ter para ser considerada válida.
set_TIP_SECURE_PASSWORD_LEVEL=Nível de segurança a ser atribuído ŕ senha de acordo com as seguintes possibilidades:<br>0 Verifica apenas se a chave está presente;<br>1 Verifica se a chave está em conformidade com o comprimento estabelecido no parâmetro SECURE_PASSWORD_LENGTH;<br>2 Além do acima, verifica se há um caractere alfabético minúsculo;<br>3 Além do acima, verifica se há pelo menos um caractere numérico;<br>4 Além do acima, verifica se há pelo menos uma letra maiúscula;<br>5 Além do acima, verifica se há pelo menos um caractere especial: .,!@#$%^&*?_~-().
set_ROOT=Defina onde os documentos vinculados serăo armazenados
set_TIP_ROOT=Indique o caminho completo para a pasta principal de documentos vinculados.<br>Sugestăo: %path_database%
set_COLLECTION=Defina onde os documentos digitais serăo armazenados.
set_TIP_COLLECTION=Indique o caminho completo para a pasta principal de documentos digitais.<br>Sugestăo: %path_database%
set_inventory_numeric=Ignorar os zeros ŕ esquerda ao ler códigos de barras?
set_TIP_inventory_numeric=Determina se, ao ler o código de barras de um item no sistema de empréstimo, os zeros ŕ esquerda săo eliminados.<br>Se o valor for S, os zeros ŕ esquerda săo apagados; se o valor for N, os zeros ŕ esquerda năo săo apagados.
set_max_inventory_length=Definir o número de caracteres do campo <b>inventário</b>
set_TIP_max_inventory_length=Indica o tamanho máximo e fixo do número de inventário. As posiçőes ausentes săo preenchidas com zero.
set_max_cn_length=Definir o número de caracteres do campo <b>número de controle</b>.
set_TIP_max_cn_length=Indica o tamanho máximo e fixo do número de controle. As posiçőes ausentes săo preenchidas com zero.
set_barcode=Ativar impressăo de código de barras?
set_TIP_barcode=Apresenta o ícone de código de barras na barra de ferramentas do módulo de catalogaçăo<br>O ícone ativa a impressăo de códigos de barras e outras etiquetas necessárias para a identificaçăo dos elementos da coleçăo.<br>O operador deve ter as permissőes correspondentes atribuídas.
set_barcode_string=Código de Barras
set_tesaurus=Tesauro
set_TIP_tesaurus=Nome do Tesauro associado ŕ base de dados
set_prefix_search_tesaurus=Prefixo do tesauro
set_TIP_prefix_search_tesaurus=Prefixo que é adicionado ao termo do tesauro para realizar a busca na base de dados ŕ qual está associado
set_leader=Líder
set_TIP_leader=Tag do primeiro campo para armazenar informaçőes do líder para um registro MARC. Se este parâmetro for omitido, as informaçőes do líder săo armazenadas no campo 3000 e acima
set_TIP_LOGIN_ERROR_PAGE=Por padrăo, quando os dados de autenticaçăo estăo incorretos, o ABCD redireciona o usuário para a página inicial do domínio. Se sua página de login estiver em um caminho diferente, use esta opçăo para redirecionar o usuário para a página correta em caso de erro de autenticaçăo.
